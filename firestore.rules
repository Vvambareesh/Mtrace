rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserHousehold() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['monthlyBudget', 'currency', 'displayName', 'householdId']);
    }

    match /households/{householdId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.members;
      allow list: if isSignedIn() && request.auth.token.email.lower() in resource.data.memberEmails;
      
      allow create: if isSignedIn() && request.resource.data.members[0] == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.members || 
        request.resource.data.memberEmails.size() > resource.data.memberEmails.size()
      );
    }

    match /expenses/{expenseId} {
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.householdId != null && resource.data.householdId == getUserHousehold())
      );
      
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.householdId != null && resource.data.householdId == getUserHousehold())
      );
      
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.householdId != null && resource.data.householdId == getUserHousehold())
      );
    }
    
    match /categories/{categoryId} {
      allow read: if isSignedIn() && (resource.data.userId == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    match /statements/{statementId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.householdId != null && resource.data.householdId == getUserHousehold())
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /bank_transactions/{transactionId} {
      allow list, get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.householdId != null && resource.data.householdId == getUserHousehold())
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.householdId != null && resource.data.householdId == getUserHousehold())
      );
    }
  }
}
